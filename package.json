    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "googleapis": "^160.0.0",
    "ngrok": "^5.0.0-beta.2"
  }
