{
  "name": "infovault",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:mobile\"",
    "dev:android": "concurrently \"npm run dev:api\" \"npm run dev:mobile:android\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:mobile": "cd apps/mobile && npm start",
    "dev:mobile:android": "cd apps/mobile && npm run android",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
